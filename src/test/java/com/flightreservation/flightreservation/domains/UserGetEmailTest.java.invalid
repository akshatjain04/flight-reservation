package com.flightreservation.flightreservation.domains;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import java.util.HashSet;
import java.util.Set;
import org.junit.jupiter.api.*;
import javax.persistence.*;

public class UserGetEmailTest {
    private User user;
    @BeforeEach
    public void setUp() {
        user = new User();
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmail() {
        String expectedEmail = "test@example.com";
        user.setEmail(expectedEmail);
        String actualEmail = user.getEmail();
        assertEquals(expectedEmail, actualEmail);
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsNullWhenNoEmailSet() {
        String actualEmail = user.getEmail();
        assertNull(actualEmail);
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsUpdatedEmail() {
        String initialEmail = "initial@example.com";
        String updatedEmail = "updated@example.com";
        user.setEmail(initialEmail);
        user.setEmail(updatedEmail);
        String actualEmail = user.getEmail();
        assertEquals(updatedEmail, actualEmail);
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailWithOtherFieldsSet() {
        String expectedEmail = "test@example.com";
        user.setFirstName("John");
        user.setLastName("Doe");
        user.setPassword("password123");
        Set<Role> roles = new HashSet<>();
        user.setRoles(roles);
        user.setEmail(expectedEmail);
        String actualEmail = user.getEmail();
        assertEquals(expectedEmail, actualEmail);
    }
    @Test
    @Tag("invalid")
    public void testGetEmailReturnsNullWhenEmailSetToNull() {
        user.setEmail(null);
        String actualEmail = user.getEmail();
        assertNull(actualEmail);
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailWithSpecialCharacters() {
        String expectedEmail = "test.email+alex@leetcode.com";
        user.setEmail(expectedEmail);
        String actualEmail = user.getEmail();
        assertEquals(expectedEmail, actualEmail);
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailWithNumbers() {
        String expectedEmail = "test123@example.com";
        user.setEmail(expectedEmail);
        String actualEmail = user.getEmail();
        assertEquals(expectedEmail, actualEmail);
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailInUppercase() {
        String expectedEmail = "TEST@EXAMPLE.COM";
        user.setEmail(expectedEmail);
        String actualEmail = user.getEmail();
        assertEquals(expectedEmail, actualEmail);
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailInLowercase() {
        String expectedEmail = "test@example.com";
        user.setEmail(expectedEmail);
        String actualEmail = user.getEmail();
        assertEquals(expectedEmail, actualEmail);
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailInMixedCase() {
        String expectedEmail = "Test@Example.com";
        user.setEmail(expectedEmail);
        String actualEmail = user.getEmail();
        assertEquals(expectedEmail, actualEmail);
    }
}