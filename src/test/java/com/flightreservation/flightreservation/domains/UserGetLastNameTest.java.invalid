package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.*;
import java.util.Set;

public class UserGetLastNameTest {
    @Test
    @Tag("valid")
    public void getLastNameReturnsCorrectLastName() {
        User user = new User();
        user.setLastName("Doe");
        assertEquals("Doe", user.getLastName());
    }
    @Test
    @Tag("valid")
    public void getLastNameReturnsNullWhenNotSet() {
        User user = new User();
        assertNull(user.getLastName());
    }
    @Test
    @Tag("boundary")
    public void getLastNameReturnsEmptyStringWhenSetToEmpty() {
        User user = new User();
        user.setLastName("");
        assertEquals("", user.getLastName());
    }
    @Test
    @Tag("valid")
    public void getLastNameReturnsUpdatedLastName() {
        User user = new User();
        user.setLastName("Smith");
        user.setLastName("Doe");
        assertEquals("Doe", user.getLastName());
    }
    @Test
    @Tag("integration")
    public void getLastNameReturnsCorrectLastNameWithOtherFieldsSet() {
        User user = new User();
        user.setFirstName("John");
        user.setLastName("Doe");
        user.setEmail("john.doe@example.com");
        user.setPassword("password123");
        // TODO: Set roles
        assertEquals("Doe", user.getLastName());
    }
}