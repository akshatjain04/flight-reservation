package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNull;
import org.junit.jupiter.api.*;
import org.springframework.security.core.GrantedAuthority;
import javax.persistence.Entity;
import javax.persistence.ManyToMany;
import java.util.Set;

public class RoleGetNameTest {
    @Test
    @Tag("valid")
    public void testGetNameReturnsCorrectRoleName() {
        Role role = new Role();
        role.setName("Admin");
        assertEquals("Admin", role.getName());
    }
    @Test
    @Tag("valid")
    public void testGetNameReturnsNullWhenNameNotSet() {
        Role role = new Role();
        assertNull(role.getName());
    }
    @Test
    @Tag("valid")
    public void testGetNameReturnsEmptyStringWhenNameIsEmpty() {
        Role role = new Role();
        role.setName("");
        assertEquals("", role.getName());
    }
    @Test
    @Tag("valid")
    public void testGetNameReturnsCorrectRoleNameAfterMultipleSets() {
        Role role = new Role();
        role.setName("User");
        role.setName("Admin");
        assertEquals("Admin", role.getName());
    }
    @Test
    @Tag("valid")
    public void testGetNameReturnsCorrectRoleNameWithSpecialCharacters() {
        Role role = new Role();
        role.setName("Role@123");
        assertEquals("Role@123", role.getName());
    }
    @Test
    @Tag("valid")
    public void testGetNameReturnsCorrectRoleNameWithNumericCharacters() {
        Role role = new Role();
        role.setName("Role123");
        assertEquals("Role123", role.getName());
    }
    @Test
    @Tag("valid")
    public void testGetNameReturnsCorrectRoleNameWithMixedCharacters() {
        Role role = new Role();
        role.setName("Role@123#");
        assertEquals("Role@123#", role.getName());
    }
}