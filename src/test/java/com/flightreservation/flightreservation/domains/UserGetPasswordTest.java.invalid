package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.*;
import java.util.Set;

public class UserGetPasswordTest {
    @Test
    @Tag("valid")
    public void getPasswordReturnsCorrectPassword() {
        User user = new User();
        user.setPassword("password123");
        assertEquals("password123", user.getPassword());
    }
    @Test
    @Tag("valid")
    public void getPasswordReturnsNullWhenNoPasswordSet() {
        User user = new User();
        assertNull(user.getPassword());
    }
    @Test
    @Tag("valid")
    public void getPasswordReturnsEmptyStringWhenEmptyPasswordSet() {
        User user = new User();
        user.setPassword("");
        assertEquals("", user.getPassword());
    }
    @Test
    @Tag("valid")
    public void getPasswordReturnsCorrectPasswordAfterUpdate() {
        User user = new User();
        user.setPassword("password123");
        user.setPassword("newPassword456");
        assertEquals("newPassword456", user.getPassword());
    }
    @Test
    @Tag("valid")
    public void getPasswordReturnsCorrectPasswordWithSpecialCharacters() {
        User user = new User();
        user.setPassword("p@ssw0rd!");
        assertEquals("p@ssw0rd!", user.getPassword());
    }
    @Test
    @Tag("valid")
    public void getPasswordReturnsCorrectPasswordWithNumericCharacters() {
        User user = new User();
        user.setPassword("password123");
        assertEquals("password123", user.getPassword());
    }
    @Test
    @Tag("valid")
    public void getPasswordReturnsCorrectPasswordWithAlphanumericCharacters() {
        User user = new User();
        user.setPassword("p@ssw0rd123");
        assertEquals("p@ssw0rd123", user.getPassword());
    }
    @Test
    @Tag("valid")
    public void getPasswordReturnsCorrectPasswordWithMixedCaseCharacters() {
        User user = new User();
        user.setPassword("P@ssw0rd");
        assertEquals("P@ssw0rd", user.getPassword());
    }
    @Test
    @Tag("valid")
    public void getPasswordReturnsCorrectPasswordWithLeadingAndTrailingSpaces() {
        User user = new User();
        user.setPassword(" password ");
        assertEquals(" password ", user.getPassword());
    }
    @Test
    @Tag("valid")
    public void getPasswordReturnsCorrectPasswordWithConsecutiveSpaces() {
        User user = new User();
        user.setPassword("pass  word");
        assertEquals("pass  word", user.getPassword());
    }
}