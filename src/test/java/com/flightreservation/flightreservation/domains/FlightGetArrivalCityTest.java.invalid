package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;
import java.sql.Timestamp;
import java.util.Date;

public class FlightGetArrivalCityTest {
    @Test
    @Tag("valid")
    public void testMethodGetArrivalCityReturnsCorrectCity() {
        Flight flight = new Flight();
        flight.setArrivalCity("New York");
        assertEquals("New York", flight.getArrivalCity());
    }
    @Test
    @Tag("invalid")
    public void testMethodGetArrivalCityReturnsNullWhenNotSet() {
        Flight flight = new Flight();
        assertNull(flight.getArrivalCity());
    }
    @Test
    @Tag("valid")
    public void testMethodGetArrivalCityReturnsEmptyStringWhenSet() {
        Flight flight = new Flight();
        flight.setArrivalCity("");
        assertEquals("", flight.getArrivalCity());
    }
    @Test
    @Tag("valid")
    public void testMethodGetArrivalCityReturnsLatestSetValue() {
        Flight flight = new Flight();
        flight.setArrivalCity("Los Angeles");
        flight.setArrivalCity("Chicago");
        assertEquals("Chicago", flight.getArrivalCity());
    }
    @Test
    @Tag("valid")
    public void testMethodGetArrivalCityHandlesSpecialCharacters() {
        Flight flight = new Flight();
        flight.setArrivalCity("New York!");
        assertEquals("New York!", flight.getArrivalCity());
    }
    @Test
    @Tag("valid")
    public void testMethodGetArrivalCityHandlesMixedCase() {
        Flight flight = new Flight();
        flight.setArrivalCity("nEw yOrK");
        assertEquals("nEw yOrK", flight.getArrivalCity());
    }
    @Test
    @Tag("valid")
    public void testMethodGetArrivalCityHandlesLeadingAndTrailingSpaces() {
        Flight flight = new Flight();
        flight.setArrivalCity(" New York ");
        assertEquals(" New York ", flight.getArrivalCity());
    }
    @Test
    @Tag("valid")
    public void testMethodGetArrivalCityHandlesUnicodeCharacters() {
        Flight flight = new Flight();
        flight.setArrivalCity("New York\uD83D\uDE00");
        assertEquals("New York\uD83D\uDE00", flight.getArrivalCity());
    }
}