package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;
import java.sql.Timestamp;
import java.util.Date;

public class FlightGetDepartureCityTest {
    @Test
    @Tag("valid")
    public void testGetDepartureCityReturnsCorrectCity() {
        Flight flight = new Flight();
        flight.setDepartureCity("New York");
        assertEquals("New York", flight.getDepartureCity());
    }
    @Test
    @Tag("valid")
    public void testGetDepartureCityReturnsNullWhenNotSet() {
        Flight flight = new Flight();
        assertNull(flight.getDepartureCity());
    }
    @Test
    @Tag("boundary")
    public void testGetDepartureCityReturnsEmptyStringWhenSetToEmpty() {
        Flight flight = new Flight();
        flight.setDepartureCity("");
        assertEquals("", flight.getDepartureCity());
    }
    @Test
    @Tag("valid")
    public void testGetDepartureCityReturnsCorrectCityAfterUpdate() {
        Flight flight = new Flight();
        flight.setDepartureCity("New York");
        flight.setDepartureCity("Los Angeles");
        assertEquals("Los Angeles", flight.getDepartureCity());
    }
    @Test
    @Tag("integration")
    public void testGetDepartureCityReturnsCorrectCityWithOtherDetailsSet() {
        Flight flight = new Flight();
        flight.setFlightNumber("AA123");
        flight.setOperatingAirlines("American Airlines");
        flight.setArrivalCity("Los Angeles");
        flight.setDateOfDeparture(new Date());
        flight.setEstimatedDepartureTime(new Timestamp(System.currentTimeMillis()));
        flight.setDepartureCity("New York");
        assertEquals("New York", flight.getDepartureCity());
    }
}