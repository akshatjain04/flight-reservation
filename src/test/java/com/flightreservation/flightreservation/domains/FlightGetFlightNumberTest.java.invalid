package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;
import java.sql.Timestamp;
import java.util.Date;

public class FlightGetFlightNumberTest {
    private Flight flight;
    @BeforeEach
    public void setUp() {
        flight = new Flight();
    }
    @Test
    @Tag("valid")
    public void testGetFlightNumberReturnsCorrectFlightNumber() {
        flight.setFlightNumber("ABC123");
        assertEquals("ABC123", flight.getFlightNumber());
    }
    @Test
    @Tag("valid")
    public void testGetFlightNumberReturnsNullWhenNotSet() {
        assertNull(flight.getFlightNumber());
    }
    @Test
    @Tag("valid")
    public void testGetFlightNumberReturnsCorrectAfterMultipleSets() {
        flight.setFlightNumber("XYZ789");
        assertEquals("XYZ789", flight.getFlightNumber());
        flight.setFlightNumber("DEF456");
        assertEquals("DEF456", flight.getFlightNumber());
    }
    @Test
    @Tag("boundary")
    public void testGetFlightNumberReturnsEmptyStringWhenSet() {
        flight.setFlightNumber("");
        assertEquals("", flight.getFlightNumber());
    }
    @Test
    @Tag("valid")
    public void testGetFlightNumberReturnsNonStandardString() {
        flight.setFlightNumber("!@#123");
        assertEquals("!@#123", flight.getFlightNumber());
    }
    @Test
    @Tag("boundary")
    public void testGetFlightNumberReturnsLongString() {
        String longString = "A".repeat(1000);
        flight.setFlightNumber(longString);
        assertEquals(longString, flight.getFlightNumber());
    }
    @Test
    @Tag("valid")
    public void testGetFlightNumberReturnsNullAfterInitialValue() {
        flight.setFlightNumber("GHI789");
        flight.setFlightNumber(null);
        assertNull(flight.getFlightNumber());
    }
}