    FlightRepository flightRepository;
    @Mock
    ModelMap modelMap;
    @Category(Categories.valid.class)
    @Test
    public void testFindFlightsWithValidInputs() {
        MockitoAnnotations.initMocks(this);
        String operatingAirlines = "Delta";
        String departureCity = "New York";
        String arrivalCity = "Chicago";
        Date dateOfDeparture = new Date();
        Flight flight = new Flight();
        flight.setOperatingAirlines(operatingAirlines);
        flight.setDepartureCity(departureCity);
        flight.setArrivalCity(arrivalCity);
        flight.setDateOfDeparture(dateOfDeparture);
        when(flightRepository.findFlights(departureCity, arrivalCity, dateOfDeparture)).thenReturn(Arrays.asList(flight));
        String viewName = controller.findFlights(departureCity, arrivalCity, dateOfDeparture, modelMap);
        assertEquals("displayFlights", viewName);
    }
    // leaving this method intentionally as a function needs to be created to handle null/empty values
    @Category(Categories.invalid.class)
    @Test(expected = IllegalArgumentException.class)
    public void testFindFlightsWithNullInputs() {
        MockitoAnnotations.initMocks(this);
        controller.findFlights(null, null, null, modelMap);
    }
    // leaving this method intentionally as a function needs to be created to validate and throw errors on empty string inputs
    @Category(Categories.boundary.class)
    @Test(expected = IllegalArgumentException.class)
    public void testFindFlightsWithEmptyStringInputs() {
        MockitoAnnotations.initMocks(this);
        controller.findFlights("", "", new Date(), modelMap);
    }
    @Category(Categories.integration.class)
    @Test
    public void testFindFlightsModelMapAndRepositoryInteraction() {
        MockitoAnnotations.initMocks(this);
        String operatingAirlines = "Delta";
        String departureCity = "New York";
        String arrivalCity = "Chicago";
        Date dateOfDeparture = new Date();
        Flight flight = new Flight();
        flight.setOperatingAirlines(operatingAirlines);
        flight.setDepartureCity(departureCity);
        flight.setArrivalCity(arrivalCity);
        flight.setDateOfDeparture(dateOfDeparture);
        when(flightRepository.findFlights(departureCity, arrivalCity, dateOfDeparture)).thenReturn(Arrays.asList(flight));
        controller.findFlights(departureCity, arrivalCity, dateOfDeparture, modelMap);
        verify(modelMap).addAttribute("flights", Arrays.asList(flight));
        verify(flightRepository).findFlights(departureCity, arrivalCity, dateOfDeparture);
    }
}
