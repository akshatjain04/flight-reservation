package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;

public class PassengerGetEmailTest {
    private Passenger passenger;
    @BeforeEach
    public void setUp() {
        passenger = new Passenger();
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmail() {
        String expectedEmail = "test@example.com";
        passenger.setEmail(expectedEmail);
        String actualEmail = passenger.getEmail();
        assertEquals(expectedEmail, actualEmail, "The email should match the one set");
    }
    @Test
    @Tag("invalid")
    public void testGetEmailReturnsNullWhenNotSet() {
        String actualEmail = passenger.getEmail();
        assertNull(actualEmail, "The email should be null when not set");
    }
    @Test
    @Tag("boundary")
    public void testGetEmailReturnsEmptyString() {
        String expectedEmail = "";
        passenger.setEmail(expectedEmail);
        String actualEmail = passenger.getEmail();
        assertEquals(expectedEmail, actualEmail, "The email should be an empty string");
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailAfterMultipleSets() {
        String firstEmail = "first@example.com";
        String secondEmail = "second@example.com";
        passenger.setEmail(firstEmail);
        passenger.setEmail(secondEmail);
        String actualEmail = passenger.getEmail();
        assertEquals(secondEmail, actualEmail, "The email should be the last one set");
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailWithOtherFieldsSet() {
        String expectedEmail = "test@example.com";
        passenger.setFirstName("John");
        passenger.setMiddleName("A");
        passenger.setLastName("Doe");
        passenger.setPhone("1234567890");
        passenger.setEmail(expectedEmail);
        String actualEmail = passenger.getEmail();
        assertEquals(expectedEmail, actualEmail, "The email should match the one set");
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailWithSpecialCharacters() {
        String expectedEmail = "test.email+alex@leetcode.com";
        passenger.setEmail(expectedEmail);
        String actualEmail = passenger.getEmail();
        assertEquals(expectedEmail, actualEmail, "The email should match the one set");
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailWithNumbers() {
        String expectedEmail = "test123@example.com";
        passenger.setEmail(expectedEmail);
        String actualEmail = passenger.getEmail();
        assertEquals(expectedEmail, actualEmail, "The email should match the one set");
    }
    @Test
    @Tag("valid")
    public void testGetEmailReturnsCorrectEmailWithMixedCase() {
        String expectedEmail = "TestEmail@example.com";
        passenger.setEmail(expectedEmail);
        String actualEmail = passenger.getEmail();
        assertEquals(expectedEmail, actualEmail, "The email should match the one set");
    }
    @Test
    @Tag("boundary")
    public void testGetEmailReturnsCorrectEmailWithLongString() {
        String expectedEmail = "thisisaverylongemailaddress@thisisaverylongdomainname.com";
        passenger.setEmail(expectedEmail);
        String actualEmail = passenger.getEmail();
        assertEquals(expectedEmail, actualEmail, "The email should match the one set");
    }
    @Test
    @Tag("boundary")
    public void testGetEmailReturnsCorrectEmailWithShortString() {
        String expectedEmail = "a@b.c";
        passenger.setEmail(expectedEmail);
        String actualEmail = passenger.getEmail();
        assertEquals(expectedEmail, actualEmail, "The email should match the one set");
    }
}