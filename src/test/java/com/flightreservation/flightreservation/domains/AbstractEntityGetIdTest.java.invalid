import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.*;
import javax.persistence.GeneratedValue;
import javax.persistence.GenerationType;
import javax.persistence.Id;
import javax.persistence.MappedSuperclass;

public class AbstractEntityGetIdTest {
    @Test
    @Tag("valid")
    public void getIdReturnsCorrectValueForPositiveId() {
        AbstractEntity entity = new AbstractEntity();
        entity.setId(1L);
        assertEquals(1L, (long) entity.getId());
    }
    @Test
    @Tag("valid")
    public void getIdReturnsCorrectValueForZeroId() {
        AbstractEntity entity = new AbstractEntity();
        entity.setId(0L);
        assertEquals(0L, (long) entity.getId());
    }
    @Test
    @Tag("valid")
    public void getIdReturnsCorrectValueForNegativeId() {
        AbstractEntity entity = new AbstractEntity();
        entity.setId(-1L);
        assertEquals(-1L, (long) entity.getId());
    }
    @Test
    @Tag("valid")
    public void getIdReturnsNullWhenIdNotSet() {
        AbstractEntity entity = new AbstractEntity();
        assertNull(entity.getId());
    }
    @Test
    @Tag("valid")
    public void getIdReturnsCorrectValueAfterMultipleSets() {
        AbstractEntity entity = new AbstractEntity();
        entity.setId(1L);
        entity.setId(2L);
        entity.setId(3L);
        assertEquals(3L, (long) entity.getId());
    }
    @Test
    @Tag("boundary")
    public void getIdReturnsCorrectValueForMaxLong() {
        AbstractEntity entity = new AbstractEntity();
        entity.setId(Long.MAX_VALUE);
        assertEquals(Long.MAX_VALUE, (long) entity.getId());
    }
    @Test
    @Tag("boundary")
    public void getIdReturnsCorrectValueForMinLong() {
        AbstractEntity entity = new AbstractEntity();
        entity.setId(Long.MIN_VALUE);
        assertEquals(Long.MIN_VALUE, (long) entity.getId());
    }
}