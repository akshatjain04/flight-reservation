package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import org.springframework.security.core.GrantedAuthority;
import javax.persistence.Entity;
import javax.persistence.ManyToMany;
import java.util.Set;

public class RoleToStringTest {
    @Test
    @Tag("valid")
    public void toStringWithNullName() {
        Role role = new Role();
        role.setName(null);
        assertEquals("Role{name='null'}", role.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithEmptyName() {
        Role role = new Role();
        role.setName("");
        assertEquals("Role{name=''}", role.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithSpecialCharactersInName() {
        Role role = new Role();
        role.setName("Role@123");
        assertEquals("Role{name='Role@123'}", role.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithSpacesInName() {
        Role role = new Role();
        role.setName("Admin Role");
        assertEquals("Role{name='Admin Role'}", role.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithUnicodeCharactersInName() {
        Role role = new Role();
        role.setName("Role名");
        assertEquals("Role{name='Role名'}", role.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithLongName() {
        Role role = new Role();
        String longName = "a".repeat(1000);
        role.setName(longName);
        assertEquals("Role{name='" + longName + "'}", role.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithNumericName() {
        Role role = new Role();
        role.setName("12345");
        assertEquals("Role{name='12345'}", role.toString());
    }
}