package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;
import java.sql.Timestamp;
import java.util.Date;

public class FlightGetOperatingAirlinesTest {
    private Flight flight;
    @BeforeEach
    public void setUp() {
        flight = new Flight();
    }
    @Test
    @Tag("valid")
    public void testGetOperatingAirlinesReturnsCorrectValue() {
        flight.setOperatingAirlines("Airline1");
        assertEquals("Airline1", flight.getOperatingAirlines());
    }
    @Test
    @Tag("valid")
    public void testGetOperatingAirlinesReturnsNullWhenNotSet() {
        assertNull(flight.getOperatingAirlines());
    }
    @Test
    @Tag("boundary")
    public void testGetOperatingAirlinesReturnsEmptyStringWhenSetToEmpty() {
        flight.setOperatingAirlines("");
        assertEquals("", flight.getOperatingAirlines());
    }
    @Test
    @Tag("valid")
    public void testGetOperatingAirlinesReturnsCorrectValueAfterMultipleSets() {
        flight.setOperatingAirlines("Airline1");
        flight.setOperatingAirlines("Airline2");
        assertEquals("Airline2", flight.getOperatingAirlines());
    }
    @Test
    @Tag("valid")
    public void testGetOperatingAirlinesReturnsCorrectValueWithOtherFieldsSet() {
        flight.setFlightNumber("FL123");
        flight.setDepartureCity("CityA");
        flight.setArrivalCity("CityB");
        flight.setDateOfDeparture(new Date());
        flight.setEstimatedDepartureTime(new Timestamp(System.currentTimeMillis()));
        flight.setOperatingAirlines("Airline1");
        assertEquals("Airline1", flight.getOperatingAirlines());
    }
}