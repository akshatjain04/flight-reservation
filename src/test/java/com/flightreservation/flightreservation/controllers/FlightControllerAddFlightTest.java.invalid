@ExtendWith(MockitoExtension.class)
public class FlightControllerAddFlightTest {
	private static final Logger LOGGER = Logger.getLogger(FlightController.class.getName());
	@Mock
	private FlightRepository flightRepository;
	@InjectMocks
	private FlightController flightController;
	@BeforeEach
	void setUp() {
		Mockito.reset(flightRepository);
	}
	@Tag("valid")
	@Test
	void testAddFlightWithValidData() {
		Flight flight = new Flight();
		// TODO: set properties to flight here
		when(flightRepository.save(Mockito.any(Flight.class))).thenReturn(flight);
		ModelMap modelMap = new ModelMap();
		String result = flightController.addFlight(flight, modelMap);
		verify(flightRepository, times(1)).save(flight);
		assertEquals("Flight Added Successfully", modelMap.getAttribute("msg"));
		assertEquals("flights/addFlight", result);
	}
	@Tag("invalid")
	@Test
	void testAddFlightWithInvalidData() {
	    Flight flight = new Flight();
	    // TODO: set invalid properties to flight here
	    when(flightRepository.save(Mockito.any(Flight.class))).thenReturn(null);
	    ModelMap modelMap = new ModelMap();
	    assertThrows(RuntimeException.class, () -> {
	    	flightController.addFlight(flight, modelMap);
	    });
	}
	@Tag("integration")
	@Test
	void testAddFlightWhenRepositoryUnavailable() {
	    Flight flight = new Flight();
	    // TODO: set valid properties to flight here
	    doThrow(new RuntimeException("Service unavailable")).when(flightRepository).save(any(Flight.class));
	    ModelMap modelMap = new ModelMap();
	    Exception exception = assertThrows(RuntimeException.class, () -> {
	        flightController.addFlight(flight, modelMap);
	    });
	    String expectedMessage = "Service unavailable";
	    String actualMessage = exception.getMessage();
	    assertEquals(expectedMessage, actualMessage);
	}
}