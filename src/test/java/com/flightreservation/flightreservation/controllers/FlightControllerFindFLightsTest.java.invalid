package com.flightreservation.flightreservation.controllers;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mockito;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.format.annotation.DateTimeFormat;
import org.springframework.ui.ModelMap;
import org.springframework.test.context.junit.jupiter.SpringExtension;
import com.flightreservation.flightreservation.domains.Flight;
import java.util.Date;
import java.util.ArrayList;
import java.util.List;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import com.flightreservation.flightreservation.repositories.FlightRepository;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;

@ExtendWith(SpringExtension.class)
public class FlightControllerFindFLightsTest {
    private FlightController flightController; 
    
    @MockBean
    private FlightRepository flightRepository;
    
    private ModelMap modelMap;
    
    @BeforeEach
    public void setUp() {
        flightController = new FlightController();
        modelMap = new ModelMap();
    }
    @Test
    @Tag("valid")
    public void validateFindFlightsWithValidInput() {
        String source = "New York"; 
        String destination = "Los Angeles";
        @DateTimeFormat(pattern = "MM-dd-yyyy") 
        Date departDate = new Date();
        
        Flight flight = new Flight();
        
        List<Flight> expectedFlights = new ArrayList<>();
        expectedFlights.add(flight);
        
        Mockito.when(flightRepository.findFlights(source, destination, departDate)).thenReturn(expectedFlights);
        
        flightController.findFlights(source, destination, departDate, modelMap);
        
        assertEquals(expectedFlights, modelMap.get("flights"));
    }
    @Test
    @Tag("invalid")
    public void validateFindFlightsWithInvalidInput() {
        String source = "Invalid Source";
        String destination = "Invalid Destination";
        @DateTimeFormat(pattern = "MM-dd-yyyy")
        Date departDate = null;
        Mockito.when(flightRepository.findFlights(source, destination, departDate)).thenReturn(new ArrayList<>());
        flightController.findFlights(source, destination, departDate, modelMap);
        
        assertTrue(((List) modelMap.get("flights")).isEmpty());
    }
    @Test
    @Tag("boundary")
    public void validateFindFlightsWithNullInput() {
        assertThrows(NullPointerException.class, () -> {
            flightController.findFlights(null, null, null, modelMap);
        });
    }
} 