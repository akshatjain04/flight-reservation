package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.*;
import java.util.Set;

public class UserGetFirstNameTest {
    @Test
    @Tag("valid")
    public void testGetFirstNameReturnsNullWhenFirstNameNotSet() {
        User user = new User();
        assertNull(user.getFirstName());
    }
    @Test
    @Tag("valid")
    public void testGetFirstNameReturnsCorrectValueWhenFirstNameSet() {
        User user = new User();
        user.setFirstName("John");
        assertEquals("John", user.getFirstName());
    }
    @Test
    @Tag("valid")
    public void testGetFirstNameReturnsEmptyStringWhenFirstNameSetToEmptyString() {
        User user = new User();
        user.setFirstName("");
        assertEquals("", user.getFirstName());
    }
    @Test
    @Tag("valid")
    public void testGetFirstNameReturnsNonEmptyStringWhenFirstNameSetToNonEmptyString() {
        User user = new User();
        user.setFirstName("Doe");
        assertEquals("Doe", user.getFirstName());
    }
    @Test
    @Tag("valid")
    public void testGetFirstNameReturnsNullWhenFirstNameSetToNullAfterInitialization() {
        User user = new User();
        user.setFirstName("Jane");
        user.setFirstName(null);
        assertNull(user.getFirstName());
    }
    @Test
    @Tag("valid")
    public void testGetFirstNameReturnsCorrectValueWhenFirstNameSetToDifferentValues() {
        User user = new User();
        user.setFirstName("Alice");
        assertEquals("Alice", user.getFirstName());
        user.setFirstName("Bob");
        assertEquals("Bob", user.getFirstName());
        user.setFirstName("Charlie");
        assertEquals("Charlie", user.getFirstName());
    }
}