package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;

public class PassengerGetLastNameTest {
    @Test
    @Tag("valid")
    public void testGetLastNameReturnsCorrectValue() {
        Passenger passenger = new Passenger();
        passenger.setLastName("Doe");
        assertEquals("Doe", passenger.getLastName());
    }
    @Test
    @Tag("valid")
    public void testGetLastNameReturnsNullWhenNotSet() {
        Passenger passenger = new Passenger();
        assertNull(passenger.getLastName());
    }
    @Test
    @Tag("valid")
    public void testGetLastNameHandlesEmptyString() {
        Passenger passenger = new Passenger();
        passenger.setLastName("");
        assertEquals("", passenger.getLastName());
    }
    @Test
    @Tag("valid")
    public void testGetLastNameHandlesSpecialCharacters() {
        Passenger passenger = new Passenger();
        passenger.setLastName("O'Connor");
        assertEquals("O'Connor", passenger.getLastName());
    }
    @Test
    @Tag("valid")
    public void testGetLastNameHandlesNumericValues() {
        Passenger passenger = new Passenger();
        passenger.setLastName("12345");
        assertEquals("12345", passenger.getLastName());
    }
    @Test
    @Tag("valid")
    public void testGetLastNameHandlesMixedCase() {
        Passenger passenger = new Passenger();
        passenger.setLastName("mIxEdCaSe");
        assertEquals("mIxEdCaSe", passenger.getLastName());
    }
    @Test
    @Tag("valid")
    public void testGetLastNameHandlesLongName() {
        Passenger passenger = new Passenger();
        String longName = "A".repeat(256); // TODO: Adjust the length as per the actual requirement
        passenger.setLastName(longName);
        assertEquals(longName, passenger.getLastName());
    }
    @Test
    @Tag("valid")
    public void testGetLastNameHandlesUnicodeCharacters() {
        Passenger passenger = new Passenger();
        passenger.setLastName("こんにちは");
        assertEquals("こんにちは", passenger.getLastName());
    }
}