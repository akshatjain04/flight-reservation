class FlightControllerShowAddFlightPageTest {
    private FlightController flightController;
    @BeforeEach
    void setup() {
        this.flightController = new FlightController();
    }
    @Test
    @Tag("valid")
    void executeShowAddFlightPage() {
        // Act
        String page = flightController.showAddFlightPage();
        // Assert
        assertEquals("flights/addFlight", page); // Expected Value: flights/addFlight
    }
    @Test
    @Tag("valid")
    void consistencyOfShowAddFlightPage() {
        // Act and Assert
        for(int i = 0; i < 5; i++)
        {
            assertEquals("flights/addFlight", flightController.showAddFlightPage());
        }
    }
    @Test
    @Tag("valid")
    void stateChangeOfFlightController() {
        // Arrange
        FlightController preExecutionFlightController = new FlightController();
        // Act
        flightController.showAddFlightPage();
        // Assert
        assertEquals(preExecutionFlightController, flightController); // Expected Value: FlightController's state is unchanged
    }
}