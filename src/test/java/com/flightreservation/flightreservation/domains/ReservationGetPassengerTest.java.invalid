package com.flightreservation.flightreservation.domains;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;
import javax.persistence.OneToOne;

public class ReservationGetPassengerTest {
    private Reservation reservation;
    @BeforeEach
    public void setUp() {
        reservation = new Reservation();
    }
    @Test
    @Tag("valid")
    public void testGetPassengerReturnsCorrectPassenger() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("John");
        passenger.setLastName("Doe");
        reservation.setPassenger(passenger);
        assertEquals(passenger, reservation.getPassenger());
    }
    @Test
    @Tag("valid")
    public void testGetPassengerReturnsNullWhenNoPassengerSet() {
        assertNull(reservation.getPassenger());
    }
    @Test
    @Tag("valid")
    public void testGetPassengerReturnsCorrectPassengerAfterUpdate() {
        Passenger passenger1 = new Passenger();
        passenger1.setFirstName("John");
        passenger1.setLastName("Doe");
        reservation.setPassenger(passenger1);
        Passenger passenger2 = new Passenger();
        passenger2.setFirstName("Jane");
        passenger2.setLastName("Doe");
        reservation.setPassenger(passenger2);
        assertEquals(passenger2, reservation.getPassenger());
    }
    @Test
    @Tag("valid")
    public void testGetPassengerReturnsCorrectPassengerInMultipleReservations() {
        Reservation reservation1 = new Reservation();
        Reservation reservation2 = new Reservation();
        Passenger passenger1 = new Passenger();
        passenger1.setFirstName("John");
        passenger1.setLastName("Doe");
        reservation1.setPassenger(passenger1);
        Passenger passenger2 = new Passenger();
        passenger2.setFirstName("Jane");
        passenger2.setLastName("Doe");
        reservation2.setPassenger(passenger2);
        assertEquals(passenger1, reservation1.getPassenger());
        assertEquals(passenger2, reservation2.getPassenger());
    }
    @Test
    @Tag("valid")
    public void testGetPassengerReturnsCorrectPassengerAfterCheckIn() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("John");
        passenger.setLastName("Doe");
        reservation.setPassenger(passenger);
        reservation.setCheckedin(true);
        assertEquals(passenger, reservation.getPassenger());
    }
    @Test
    @Tag("valid")
    public void testGetPassengerReturnsCorrectPassengerAfterUpdatingBags() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("John");
        passenger.setLastName("Doe");
        reservation.setPassenger(passenger);
        reservation.setNumberOfBags(2);
        assertEquals(passenger, reservation.getPassenger());
    }
}