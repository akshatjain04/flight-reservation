package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;

public class PassengerGetFirstNameTest {
    @Test
    @Tag("valid")
    public void getFirstNameReturnsCorrectFirstName() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("John");
        assertEquals("John", passenger.getFirstName());
    }
    @Test
    @Tag("valid")
    public void getFirstNameReturnsNullWhenNotSet() {
        Passenger passenger = new Passenger();
        assertNull(passenger.getFirstName());
    }
    @Test
    @Tag("boundary")
    public void getFirstNameReturnsEmptyStringWhenSetToEmpty() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("");
        assertEquals("", passenger.getFirstName());
    }
    @Test
    @Tag("valid")
    public void getFirstNameReturnsNonEmptyStringWhenSetToNonEmpty() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("Jane");
        assertEquals("Jane", passenger.getFirstName());
    }
    @Test
    @Tag("valid")
    public void getFirstNameReturnsCorrectFirstNameAfterMultipleSetOperations() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("Alice");
        assertEquals("Alice", passenger.getFirstName());
        passenger.setFirstName("Bob");
        assertEquals("Bob", passenger.getFirstName());
        passenger.setFirstName("Charlie");
        assertEquals("Charlie", passenger.getFirstName());
    }
    @Test
    @Tag("valid")
    public void getFirstNameReturnsCorrectFirstNameWhenOtherFieldsAreSet() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("David");
        passenger.setMiddleName("L");
        passenger.setLastName("Smith");
        passenger.setEmail("david.smith@example.com");
        passenger.setPhone("1234567890");
        assertEquals("David", passenger.getFirstName());
    }
    @Test
    @Tag("valid")
    public void getFirstNameReturnsCorrectFirstNameWithSpecialCharacters() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("J@ne-Doe");
        assertEquals("J@ne-Doe", passenger.getFirstName());
    }
    @Test
    @Tag("boundary")
    public void getFirstNameReturnsCorrectFirstNameWithLeadingAndTrailingSpaces() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("  Emily  ");
        assertEquals("  Emily  ", passenger.getFirstName());
    }
}