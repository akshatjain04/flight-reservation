package com.flightreservation.flightreservation.domains;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNull;
import static org.junit.jupiter.api.Assertions.assertTrue;
import java.util.Date;
import java.util.Calendar;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;
import java.sql.Timestamp;

public class FlightGetDateOfDepartureTest {
    private Flight flight;
    @BeforeEach
    public void setUp() {
        flight = new Flight();
    }
    @Test
    @Tag("valid")
    public void getDateOfDepartureReturnsCorrectDate() {
        Date expectedDate = new Date();
        flight.setDateOfDeparture(expectedDate);
        Date actualDate = flight.getDateOfDeparture();
        assertEquals(expectedDate, actualDate);
    }
    @Test
    @Tag("valid")
    public void getDateOfDepartureReturnsNullWhenNotSet() {
        Date actualDate = flight.getDateOfDeparture();
        assertNull(actualDate);
    }
    @Test
    @Tag("valid")
    public void getDateOfDepartureReturnsCorrectDateAfterMultipleSets() {
        Date firstDate = new Date();
        Date secondDate = new Date();
        flight.setDateOfDeparture(firstDate);
        flight.setDateOfDeparture(secondDate);
        Date actualDate = flight.getDateOfDeparture();
        assertEquals(secondDate, actualDate);
    }
    @Test
    @Tag("valid")
    public void getDateOfDepartureReturnsCorrectDateForCurrentDate() {
        Date currentDate = new Date();
        flight.setDateOfDeparture(currentDate);
        Date actualDate = flight.getDateOfDeparture();
        assertEquals(currentDate, actualDate);
    }
    @Test
    @Tag("valid")
    public void getDateOfDepartureReturnsCorrectDateForFutureDate() {
        Calendar calendar = Calendar.getInstance();
        calendar.add(Calendar.DAY_OF_YEAR, 10);
        Date futureDate = calendar.getTime();
        flight.setDateOfDeparture(futureDate);
        Date actualDate = flight.getDateOfDeparture();
        assertEquals(futureDate, actualDate);
    }
    @Test
    @Tag("valid")
    public void getDateOfDepartureReturnsCorrectDateForPastDate() {
        Calendar calendar = Calendar.getInstance();
        calendar.add(Calendar.DAY_OF_YEAR, -10);
        Date pastDate = calendar.getTime();
        flight.setDateOfDeparture(pastDate);
        Date actualDate = flight.getDateOfDeparture();
        assertEquals(pastDate, actualDate);
    }
    @Test
    @Tag("boundary")
    public void getDateOfDepartureReturnsCorrectDateForMaxDate() {
        Calendar calendar = Calendar.getInstance();
        calendar.set(Calendar.YEAR, 9999);
        calendar.set(Calendar.MONTH, 11);
        calendar.set(Calendar.DAY_OF_MONTH, 31);
        Date maxDate = calendar.getTime();
        flight.setDateOfDeparture(maxDate);
        Date actualDate = flight.getDateOfDeparture();
        assertEquals(maxDate, actualDate);
    }
    @Test
    @Tag("boundary")
    public void getDateOfDepartureReturnsCorrectDateForMinDate() {
        Calendar calendar = Calendar.getInstance();
        calendar.set(Calendar.YEAR, 1970);
        calendar.set(Calendar.MONTH, 0);
        calendar.set(Calendar.DAY_OF_MONTH, 1);
        Date minDate = calendar.getTime();
        flight.setDateOfDeparture(minDate);
        Date actualDate = flight.getDateOfDeparture();
        assertEquals(minDate, actualDate);
    }
}