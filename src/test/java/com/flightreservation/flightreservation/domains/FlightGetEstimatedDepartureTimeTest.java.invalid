package com.flightreservation.flightreservation.domains;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNull;
import static org.junit.jupiter.api.Assertions.assertTrue;
import java.sql.Timestamp;
import java.time.LocalDateTime;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;
import java.util.Date;

public class FlightGetEstimatedDepartureTimeTest {
    private Flight flight;
    @BeforeEach
    public void setUp() {
        flight = new Flight();
    }
    @Test
    @Tag("valid")
    public void testGetEstimatedDepartureTimeReturnsCorrectTimestamp() {
        Timestamp expectedTimestamp = Timestamp.valueOf(LocalDateTime.of(2023, 10, 1, 12, 0));
        flight.setEstimatedDepartureTime(expectedTimestamp);
        assertEquals(expectedTimestamp, flight.getEstimatedDepartureTime());
    }
    @Test
    @Tag("valid")
    public void testGetEstimatedDepartureTimeReturnsNullWhenNotSet() {
        assertNull(flight.getEstimatedDepartureTime());
    }
    @Test
    @Tag("valid")
    public void testGetEstimatedDepartureTimeReturnsValidTimestamp() {
        Timestamp expectedTimestamp = Timestamp.valueOf(LocalDateTime.of(2023, 10, 1, 12, 0));
        flight.setEstimatedDepartureTime(expectedTimestamp);
        assertEquals(expectedTimestamp, flight.getEstimatedDepartureTime());
    }
    @Test
    @Tag("boundary")
    public void testGetEstimatedDepartureTimeReturnsMinimumTimestamp() {
        Timestamp expectedTimestamp = Timestamp.valueOf("1970-01-01 00:00:01");
        flight.setEstimatedDepartureTime(expectedTimestamp);
        assertEquals(expectedTimestamp, flight.getEstimatedDepartureTime());
    }
    @Test
    @Tag("boundary")
    public void testGetEstimatedDepartureTimeReturnsMaximumTimestamp() {
        Timestamp expectedTimestamp = Timestamp.valueOf("2038-01-19 03:14:07");
        flight.setEstimatedDepartureTime(expectedTimestamp);
        assertEquals(expectedTimestamp, flight.getEstimatedDepartureTime());
    }
    @Test
    @Tag("valid")
    public void testGetEstimatedDepartureTimeReturnsFutureTimestamp() {
        Timestamp expectedTimestamp = Timestamp.valueOf(LocalDateTime.now().plusDays(1));
        flight.setEstimatedDepartureTime(expectedTimestamp);
        assertEquals(expectedTimestamp, flight.getEstimatedDepartureTime());
    }
    @Test
    @Tag("valid")
    public void testGetEstimatedDepartureTimeReturnsPastTimestamp() {
        Timestamp expectedTimestamp = Timestamp.valueOf(LocalDateTime.now().minusDays(1));
        flight.setEstimatedDepartureTime(expectedTimestamp);
        assertEquals(expectedTimestamp, flight.getEstimatedDepartureTime());
    }
    @Test
    @Tag("valid")
    public void testGetEstimatedDepartureTimeReturnsCurrentTimestamp() {
        Timestamp expectedTimestamp = Timestamp.valueOf(LocalDateTime.now());
        flight.setEstimatedDepartureTime(expectedTimestamp);
        assertTrue(flight.getEstimatedDepartureTime().getTime() - expectedTimestamp.getTime() < 1000);
    }
}