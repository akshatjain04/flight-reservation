package com.flightreservation.flightreservation.domains;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.when;
import java.sql.Timestamp;
import java.util.Date;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import javax.persistence.Entity;
import javax.persistence.OneToOne;
import org.junit.jupiter.api.*;

@Entity
public class ReservationToStringTest extends AbstractEntity {
    private boolean checkedIn;
    private int numberOfBags;
    private Passenger passenger;
    private Flight flight;
    public boolean isCheckedin() {
        return checkedIn;
    }
    public void setCheckedin(boolean checkedin) {
        this.checkedIn = checkedin;
    }
    public int getNumberOfBags() {
        return numberOfBags;
    }
    public void setNumberOfBags(int numberOfBags) {
        this.numberOfBags = numberOfBags;
    }
    public Passenger getPassenger() {
        return passenger;
    }
    public void setPassenger(Passenger passenger) {
        this.passenger = passenger;
    }
    public Flight getFlight() {
        return flight;
    }
    public void setFlight(Flight flight) {
        this.flight = flight;
    }
    public String toString() {
        return "Reservation{" + "checkedin=" + checkedIn + ", numberOfBags=" + numberOfBags + ", passenger=" + passenger + ", flight=" + flight + '}';
    }
    @BeforeEach
    public void setUp() {
        passenger = mock(Passenger.class);
        flight = mock(Flight.class);
    }
    @Test
    @Tag("valid")
    public void testToStringWithAllFieldsSet() {
        when(passenger.toString()).thenReturn("Passenger{firstName='John', lastName='Doe'}");
        when(flight.toString()).thenReturn("Flight{flightNumber='123', operatingAirlines='Airline'}");
        setCheckedin(true);
        setNumberOfBags(2);
        setPassenger(passenger);
        setFlight(flight);
        String expected = "Reservation{checkedin=true, numberOfBags=2, passenger=Passenger{firstName='John', lastName='Doe'}, flight=Flight{flightNumber='123', operatingAirlines='Airline'}}";
        assertEquals(expected, toString());
    }
    @Test
    @Tag("valid")
    public void testToStringWithDefaultValues() {
        String expected = "Reservation{checkedin=false, numberOfBags=0, passenger=null, flight=null}";
        assertEquals(expected, toString());
    }
    @Test
    @Tag("boundary")
    public void testToStringWithMinimumValidValues() {
        setCheckedin(false);
        setNumberOfBags(0);
        setPassenger(null);
        setFlight(null);
        String expected = "Reservation{checkedin=false, numberOfBags=0, passenger=null, flight=null}";
        assertEquals(expected, toString());
    }
    @Test
    @Tag("boundary")
    public void testToStringWithMaximumValidValues() {
        setCheckedin(true);
        setNumberOfBags(Integer.MAX_VALUE);
        setPassenger(passenger);
        setFlight(flight);
        when(passenger.toString()).thenReturn("Passenger{firstName='John', lastName='Doe'}");
        when(flight.toString()).thenReturn("Flight{flightNumber='123', operatingAirlines='Airline'}");
        String expected = "Reservation{checkedin=true, numberOfBags=" + Integer.MAX_VALUE + ", passenger=Passenger{firstName='John', lastName='Doe'}, flight=Flight{flightNumber='123', operatingAirlines='Airline'}}";
        assertEquals(expected, toString());
    }
    @Test
    @Tag("invalid")
    public void testToStringWithNullPassengerAndFlight() {
        setCheckedin(true);
        setNumberOfBags(2);
        setPassenger(null);
        setFlight(null);
        String expected = "Reservation{checkedin=true, numberOfBags=2, passenger=null, flight=null}";
        assertEquals(expected, toString());
    }
    @Test
    @Tag("valid")
    public void testToStringWithSpecialCharacters() {
        when(passenger.toString()).thenReturn("Passenger{firstName='J@hn', lastName='D@e'}");
        when(flight.toString()).thenReturn("Flight{flightNumber='1@3', operatingAirlines='@irline'}");
        setCheckedin(true);
        setNumberOfBags(2);
        setPassenger(passenger);
        setFlight(flight);
        String expected = "Reservation{checkedin=true, numberOfBags=2, passenger=Passenger{firstName='J@hn', lastName='D@e'}, flight=Flight{flightNumber='1@3', operatingAirlines='@irline'}}";
        assertEquals(expected, toString());
    }
    @Test
    @Tag("boundary")
    public void testToStringWithLargeNumberOfBags() {
        setCheckedin(true);
        setNumberOfBags(Integer.MAX_VALUE);
        setPassenger(passenger);
        setFlight(flight);
        when(passenger.toString()).thenReturn("Passenger{firstName='John', lastName='Doe'}");
        when(flight.toString()).thenReturn("Flight{flightNumber='123', operatingAirlines='Airline'}");
        String expected = "Reservation{checkedin=true, numberOfBags=" + Integer.MAX_VALUE + ", passenger=Passenger{firstName='John', lastName='Doe'}, flight=Flight{flightNumber='123', operatingAirlines='Airline'}}";
        assertEquals(expected, toString());
    }
    @Test
    @Tag("invalid")
    public void testToStringWithNegativeNumberOfBags() {
        setCheckedin(true);
        setNumberOfBags(-1);
        setPassenger(passenger);
        setFlight(flight);
        when(passenger.toString()).thenReturn("Passenger{firstName='John', lastName='Doe'}");
        when(flight.toString()).thenReturn("Flight{flightNumber='123', operatingAirlines='Airline'}");
        String expected = "Reservation{checkedin=true, numberOfBags=-1, passenger=Passenger{firstName='John', lastName='Doe'}, flight=Flight{flightNumber='123', operatingAirlines='Airline'}}";
        assertEquals(expected, toString());
    }
    @Test
    @Tag("valid")
    public void testToStringWithBooleanFields() {
        setCheckedin(true);
        setNumberOfBags(2);
        setPassenger(passenger);
        setFlight(flight);
        when(passenger.toString()).thenReturn("Passenger{firstName='John', lastName='Doe'}");
        when(flight.toString()).thenReturn("Flight{flightNumber='123', operatingAirlines='Airline'}");
        String expectedTrue = "Reservation{checkedin=true, numberOfBags=2, passenger=Passenger{firstName='John', lastName='Doe'}, flight=Flight{flightNumber='123', operatingAirlines='Airline'}}";
        assertEquals(expectedTrue, toString());
        setCheckedin(false);
        String expectedFalse = "Reservation{checkedin=false, numberOfBags=2, passenger=Passenger{firstName='John', lastName='Doe'}, flight=Flight{flightNumber='123', operatingAirlines='Airline'}}";
        assertEquals(expectedFalse, toString());
    }
    @Test
    @Tag("integration")
    public void testToStringWithComplexPassengerAndFlight() {
        when(passenger.toString()).thenReturn("Passenger{firstName='John', middleName='A', lastName='Doe', email='john.doe@example.com', phone='1234567890'}");
        when(flight.toString()).thenReturn("Flight{flightNumber='123', operatingAirlines='Airline', departureCity='CityA', arrivalCity='CityB', dateOfDeparture=" + new Date() + ", estimatedDepartureTime=" + new Timestamp(System.currentTimeMillis()) + "}");
        setCheckedin(true);
        setNumberOfBags(2);
        setPassenger(passenger);
        setFlight(flight);
        String expected = "Reservation{checkedin=true, numberOfBags=2, passenger=Passenger{firstName='John', middleName='A', lastName='Doe', email='john.doe@example.com', phone='1234567890'}, flight=Flight{flightNumber='123', operatingAirlines='Airline', departureCity='CityA', arrivalCity='CityB', dateOfDeparture=" + new Date() + ", estimatedDepartureTime=" + new Timestamp(System.currentTimeMillis()) + "}}";
        assertEquals(expected, toString());
    }
}