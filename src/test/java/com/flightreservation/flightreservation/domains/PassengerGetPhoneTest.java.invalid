package com.flightreservation.flightreservation.domains;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNull;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;

public class PassengerGetPhoneTest {
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsCorrectPhoneNumber() {
        Passenger passenger = new Passenger();
        passenger.setPhone("1234567890");
        assertEquals("1234567890", passenger.getPhone());
    }
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsNullWhenPhoneNotSet() {
        Passenger passenger = new Passenger();
        assertNull(passenger.getPhone());
    }
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsCorrectPhoneNumberAfterUpdate() {
        Passenger passenger = new Passenger();
        passenger.setPhone("1234567890");
        passenger.setPhone("0987654321");
        assertEquals("0987654321", passenger.getPhone());
    }
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsCorrectPhoneNumberWithSpecialCharacters() {
        Passenger passenger = new Passenger();
        passenger.setPhone("123-456-7890");
        assertEquals("123-456-7890", passenger.getPhone());
    }
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsCorrectPhoneNumberWithInternationalFormat() {
        Passenger passenger = new Passenger();
        passenger.setPhone("+1-123-456-7890");
        assertEquals("+1-123-456-7890", passenger.getPhone());
    }
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsCorrectPhoneNumberWithSpaces() {
        Passenger passenger = new Passenger();
        passenger.setPhone("123 456 7890");
        assertEquals("123 456 7890", passenger.getPhone());
    }
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsCorrectPhoneNumberWithDashes() {
        Passenger passenger = new Passenger();
        passenger.setPhone("123-456-7890");
        assertEquals("123-456-7890", passenger.getPhone());
    }
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsCorrectPhoneNumberWithParentheses() {
        Passenger passenger = new Passenger();
        passenger.setPhone("(123) 456-7890");
        assertEquals("(123) 456-7890", passenger.getPhone());
    }
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsCorrectPhoneNumberWithPlusSign() {
        Passenger passenger = new Passenger();
        passenger.setPhone("+1234567890");
        assertEquals("+1234567890", passenger.getPhone());
    }
    @Test
    @Tag("valid")
    public void testGetPhoneReturnsCorrectPhoneNumberWithLeadingZeros() {
        Passenger passenger = new Passenger();
        passenger.setPhone("001234567890");
        assertEquals("001234567890", passenger.getPhone());
    }
}