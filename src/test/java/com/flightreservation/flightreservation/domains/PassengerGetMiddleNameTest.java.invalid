package com.flightreservation.flightreservation.domains;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNull;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;

public class PassengerGetMiddleNameTest {
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsCorrectMiddleName() {
        Passenger passenger = new Passenger();
        passenger.setMiddleName("John");
        assertEquals("John", passenger.getMiddleName());
    }
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsNullWhenNotSet() {
        Passenger passenger = new Passenger();
        assertNull(passenger.getMiddleName());
    }
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsEmptyStringWhenSetToEmpty() {
        Passenger passenger = new Passenger();
        passenger.setMiddleName("");
        assertEquals("", passenger.getMiddleName());
    }
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsUpdatedMiddleName() {
        Passenger passenger = new Passenger();
        passenger.setMiddleName("John");
        passenger.setMiddleName("Doe");
        assertEquals("Doe", passenger.getMiddleName());
    }
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsCorrectMiddleNameWithOtherFieldsSet() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("Jane");
        passenger.setMiddleName("Mary");
        passenger.setLastName("Doe");
        passenger.setEmail("jane.doe@example.com");
        passenger.setPhone("1234567890");
        assertEquals("Mary", passenger.getMiddleName());
    }
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsNullWhenSetToNullAfterInitialSet() {
        Passenger passenger = new Passenger();
        passenger.setMiddleName("John");
        passenger.setMiddleName(null);
        assertNull(passenger.getMiddleName());
    }
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsCorrectMiddleNameWithSpecialCharacters() {
        Passenger passenger = new Passenger();
        passenger.setMiddleName("J@hn");
        assertEquals("J@hn", passenger.getMiddleName());
    }
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsCorrectMiddleNameWithNumericCharacters() {
        Passenger passenger = new Passenger();
        passenger.setMiddleName("J0hn");
        assertEquals("J0hn", passenger.getMiddleName());
    }
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsCorrectMiddleNameWithLeadingAndTrailingSpaces() {
        Passenger passenger = new Passenger();
        passenger.setMiddleName(" John ");
        assertEquals(" John ", passenger.getMiddleName());
    }
    @Test
    @Tag("valid")
    public void getMiddleNameReturnsCorrectMiddleNameWithOnlySpaces() {
        Passenger passenger = new Passenger();
        passenger.setMiddleName("   ");
        assertEquals("   ", passenger.getMiddleName());
    }
}