package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.security.core.GrantedAuthority;
import javax.persistence.Entity;
import javax.persistence.ManyToMany;
import java.util.HashSet;
import java.util.Set;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertTrue;
import org.junit.jupiter.api.*;

@Entity
public class RoleGetUsersTest extends AbstractEntity implements GrantedAuthority {
    private String name;
    private Set<User> users;
    @BeforeEach
    public void setUp() {
        users = new HashSet<>();
    }
    @Test
    @Tag("valid")
    public void testGetUsersReturnsCorrectSetOfUsers() {
        Role role = new Role();
        Set<User> expectedUsers = new HashSet<>();
        expectedUsers.add(new User());
        role.setUsers(expectedUsers);
        Set<User> actualUsers = role.getUsers();
        assertEquals(expectedUsers, actualUsers);
    }
    @Test
    @Tag("valid")
    public void testGetUsersReturnsEmptySetWhenNoUsersAssigned() {
        Role role = new Role();
        Set<User> actualUsers = role.getUsers();
        assertTrue(actualUsers.isEmpty());
    }
    @Test
    @Tag("valid")
    public void testGetUsersReturnsSameSetAfterMultipleAssignments() {
        Role role = new Role();
        Set<User> firstSetOfUsers = new HashSet<>();
        firstSetOfUsers.add(new User());
        role.setUsers(firstSetOfUsers);
        Set<User> actualUsers = role.getUsers();
        assertEquals(firstSetOfUsers, actualUsers);
        Set<User> secondSetOfUsers = new HashSet<>();
        secondSetOfUsers.add(new User());
        role.setUsers(secondSetOfUsers);
        actualUsers = role.getUsers();
        assertEquals(secondSetOfUsers, actualUsers);
    }
    @Test
    @Tag("valid")
    public void testGetUsersReturnsEmptySetAfterSettingUsersToNull() {
        Role role = new Role();
        Set<User> initialUsers = new HashSet<>();
        initialUsers.add(new User());
        role.setUsers(initialUsers);
        Set<User> actualUsers = role.getUsers();
        assertTrue(actualUsers != null);
        role.setUsers(null);
        actualUsers = role.getUsers();
        assertTrue(actualUsers.isEmpty());
    }
    @Test
    @Tag("valid")
    public void testGetUsersReturnsEmptySetWhenUsersNotInitialized() {
        Role role = new Role();
        Set<User> actualUsers = role.getUsers();
        assertTrue(actualUsers.isEmpty());
    }
    @Test
    @Tag("valid")
    public void testGetUsersReturnsEmptySetWhenUsersInitializedToEmptySet() {
        Role role = new Role();
        role.setUsers(new HashSet<>());
        Set<User> actualUsers = role.getUsers();
        assertTrue(actualUsers.isEmpty());
    }
    @Test
    @Tag("valid")
    public void testGetUsersReturnsNonEmptySetWhenUsersInitializedToNonEmptySet() {
        Role role = new Role();
        Set<User> expectedUsers = new HashSet<>();
        expectedUsers.add(new User());
        role.setUsers(expectedUsers);
        Set<User> actualUsers = role.getUsers();
        assertEquals(expectedUsers, actualUsers);
    }
    @Test
    @Tag("valid")
    public void testGetUsersReturnsSameSetAfterSettingUsersToNullAndThenBackToNonEmptySet() {
        Role role = new Role();
        Set<User> initialUsers = new HashSet<>();
        initialUsers.add(new User());
        role.setUsers(initialUsers);
        Set<User> actualUsers = role.getUsers();
        assertTrue(actualUsers != null);
        role.setUsers(null);
        actualUsers = role.getUsers();
        assertTrue(actualUsers.isEmpty());
        role.setUsers(initialUsers);
        actualUsers = role.getUsers();
        assertEquals(initialUsers, actualUsers);
    }
    @Override
    public String getAuthority() {
        return name;
    }
}