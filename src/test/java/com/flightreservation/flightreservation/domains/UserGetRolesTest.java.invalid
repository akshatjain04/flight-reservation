package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import javax.persistence.*;
import java.util.HashSet;
import java.util.Set;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;

public class UserGetRolesTest {
    private User user;
    @BeforeEach
    public void setUp() {
        user = new User();
    }
    @Tag("valid")
    @Test
    public void getRolesReturnsEmptySetWhenNoRolesAssigned() {
        Set<Role> roles = user.getRoles();
        assertTrue(roles.isEmpty(), "The roles set should be empty when no roles are assigned.");
    }
    @Tag("valid")
    @Test
    public void getRolesReturnsNonEmptySetWhenRolesAssigned() {
        Role role = new Role();
        role.setName("ROLE_USER");
        Set<Role> roles = new HashSet<>();
        roles.add(role);
        user.setRoles(roles);
        Set<Role> returnedRoles = user.getRoles();
        assertFalse(returnedRoles.isEmpty(), "The roles set should not be empty when roles are assigned.");
        assertEquals(1, returnedRoles.size(), "The roles set should contain exactly one role.");
        assertTrue(returnedRoles.contains(role), "The roles set should contain the assigned role.");
    }
    @Tag("invalid")
    @Test
    public void getRolesReturnsEmptySetWhenRolesAreCleared() {
        Role role = new Role();
        role.setName("ROLE_USER");
        Set<Role> roles = new HashSet<>();
        roles.add(role);
        user.setRoles(roles);
        user.setRoles(new HashSet<>());
        Set<Role> returnedRoles = user.getRoles();
        assertTrue(returnedRoles.isEmpty(), "The roles set should be empty after clearing the roles.");
    }
    @Tag("boundary")
    @Test
    public void getRolesReturnsSetWithMultipleRoles() {
        Role role1 = new Role();
        role1.setName("ROLE_USER");
        Role role2 = new Role();
        role2.setName("ROLE_ADMIN");
        Set<Role> roles = new HashSet<>();
        roles.add(role1);
        roles.add(role2);
        user.setRoles(roles);
        Set<Role> returnedRoles = user.getRoles();
        assertFalse(returnedRoles.isEmpty(), "The roles set should not be empty when multiple roles are assigned.");
        assertEquals(2, returnedRoles.size(), "The roles set should contain exactly two roles.");
        assertTrue(returnedRoles.contains(role1), "The roles set should contain the first assigned role.");
        assertTrue(returnedRoles.contains(role2), "The roles set should contain the second assigned role.");
    }
}