package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;

public class PassengerToStringTest {
    @Test
    @Tag("valid")
    public void toStringWithAllFieldsSet() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("John");
        passenger.setMiddleName("A");
        passenger.setLastName("Doe");
        passenger.setEmail("john.doe@example.com");
        passenger.setPhone("1234567890");
        String expected = "Passenger{firstName='John', middleName='A', lastName='Doe', email='john.doe@example.com', phone='1234567890'}";
        assertEquals(expected, passenger.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithNullMiddleName() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("John");
        passenger.setMiddleName(null);
        passenger.setLastName("Doe");
        passenger.setEmail("john.doe@example.com");
        passenger.setPhone("1234567890");
        String expected = "Passenger{firstName='John', middleName='null', lastName='Doe', email='john.doe@example.com', phone='1234567890'}";
        assertEquals(expected, passenger.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithEmptyStrings() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("");
        passenger.setMiddleName("");
        passenger.setLastName("");
        passenger.setEmail("");
        passenger.setPhone("");
        String expected = "Passenger{firstName='', middleName='', lastName='', email='', phone=''}";
        assertEquals(expected, passenger.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithSpecialCharacters() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("J@hn");
        passenger.setMiddleName("A#");
        passenger.setLastName("D$e");
        passenger.setEmail("john.doe@ex@mple.com");
        passenger.setPhone("123-456-7890");
        String expected = "Passenger{firstName='J@hn', middleName='A#', lastName='D$e', email='john.doe@ex@mple.com', phone='123-456-7890'}";
        assertEquals(expected, passenger.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithAllFieldsNull() {
        Passenger passenger = new Passenger();
        String expected = "Passenger{firstName='null', middleName='null', lastName='null', email='null', phone='null'}";
        assertEquals(expected, passenger.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithMixedCaseNames() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("jOhN");
        passenger.setMiddleName("a");
        passenger.setLastName("dOe");
        passenger.setEmail("john.doe@example.com");
        passenger.setPhone("1234567890");
        String expected = "Passenger{firstName='jOhN', middleName='a', lastName='dOe', email='john.doe@example.com', phone='1234567890'}";
        assertEquals(expected, passenger.toString());
    }
    @Test
    @Tag("valid")
    public void toStringWithNumericValues() {
        Passenger passenger = new Passenger();
        passenger.setFirstName("123");
        passenger.setMiddleName("456");
        passenger.setLastName("789");
        passenger.setEmail("123.456@example.com");
        passenger.setPhone("1234567890");
        String expected = "Passenger{firstName='123', middleName='456', lastName='789', email='123.456@example.com', phone='1234567890'}";
        assertEquals(expected, passenger.toString());
    }
}