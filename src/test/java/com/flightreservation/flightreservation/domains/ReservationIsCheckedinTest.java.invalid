package com.flightreservation.flightreservation.domains;
import static org.junit.jupiter.api.Assertions.assertFalse;
import static org.junit.jupiter.api.Assertions.assertTrue;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.*;
import javax.persistence.Entity;
import javax.persistence.OneToOne;

public class ReservationIsCheckedinTest {
    private Reservation reservation;
    @BeforeEach
    public void setUp() {
        reservation = new Reservation();
    }
    @Test
    @Tag("valid")
    public void testIsCheckedinReturnsFalseWhenCheckedInIsNotSet() {
        assertFalse(reservation.isCheckedin());
    }
    @Test
    @Tag("valid")
    public void testIsCheckedinReturnsTrueWhenCheckedInIsSetToTrue() {
        reservation.setCheckedin(true);
        assertTrue(reservation.isCheckedin());
    }
    @Test
    @Tag("valid")
    public void testIsCheckedinReturnsFalseWhenCheckedInIsSetToFalse() {
        reservation.setCheckedin(false);
        assertFalse(reservation.isCheckedin());
    }
    @Test
    @Tag("valid")
    public void testIsCheckedinReturnsTrueAfterSettingCheckedInToTrueMultipleTimes() {
        reservation.setCheckedin(true);
        reservation.setCheckedin(true);
        assertTrue(reservation.isCheckedin());
    }
    @Test
    @Tag("valid")
    public void testIsCheckedinReturnsFalseAfterSettingCheckedInToFalseMultipleTimes() {
        reservation.setCheckedin(false);
        reservation.setCheckedin(false);
        assertFalse(reservation.isCheckedin());
    }
    @Test
    @Tag("valid")
    public void testIsCheckedinReturnsTrueAfterSettingCheckedInToTrueAndFalse() {
        reservation.setCheckedin(true);
        reservation.setCheckedin(false);
        assertFalse(reservation.isCheckedin());
    }
    @Test
    @Tag("valid")
    public void testIsCheckedinReturnsFalseAfterSettingCheckedInToFalseAndTrue() {
        reservation.setCheckedin(false);
        reservation.setCheckedin(true);
        assertTrue(reservation.isCheckedin());
    }
}