import javax.persistence.Entity;
import javax.persistence.OneToOne;

public class ReservationGetNumberOfBagsTest {
    @Test
    @Tag("valid")
    public void testDefaultNumberOfBags() {
        Reservation reservation = new Reservation();
        assertEquals(0, reservation.getNumberOfBags());
    }
    @Test
    @Tag("valid")
    public void testSetPositiveNumberOfBags() {
        Reservation reservation = new Reservation();
        reservation.setNumberOfBags(2);
        assertEquals(2, reservation.getNumberOfBags());
    }
    @Test
    @Tag("valid")
    public void testSetZeroNumberOfBags() {
        Reservation reservation = new Reservation();
        reservation.setNumberOfBags(0);
        assertEquals(0, reservation.getNumberOfBags());
    }
    @Test
    @Tag("valid")
    public void testSetNegativeNumberOfBags() {
        Reservation reservation = new Reservation();
        reservation.setNumberOfBags(-1);
        assertEquals(-1, reservation.getNumberOfBags());
    }
    @Test
    @Tag("valid")
    public void testSetNumberOfBagsAfterCheckIn() {
        Reservation reservation = new Reservation();
        reservation.setCheckedin(true);
        reservation.setNumberOfBags(1);
        assertEquals(1, reservation.getNumberOfBags());
    }
    @Test
    @Tag("valid")
    public void testSetNumberOfBagsBeforeCheckIn() {
        Reservation reservation = new Reservation();
        reservation.setCheckedin(false);
        reservation.setNumberOfBags(1);
        assertEquals(1, reservation.getNumberOfBags());
    }
    @Test
    @Tag("boundary")
    public void testSetNumberOfBagsMaxValue() {
        Reservation reservation = new Reservation();
        reservation.setNumberOfBags(Integer.MAX_VALUE);
        assertEquals(Integer.MAX_VALUE, reservation.getNumberOfBags());
    }
    @Test
    @Tag("boundary")
    public void testSetNumberOfBagsMinValue() {
        Reservation reservation = new Reservation();
        reservation.setNumberOfBags(Integer.MIN_VALUE);
        assertEquals(Integer.MIN_VALUE, reservation.getNumberOfBags());
    }
