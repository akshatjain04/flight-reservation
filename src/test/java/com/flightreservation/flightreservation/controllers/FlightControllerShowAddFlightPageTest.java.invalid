public class FlightControllerShowAddFlightPageTest {
    private FlightController flightController;
    private ViewResolver viewResolver;
    @BeforeEach
    public void setup() {
        flightController = new FlightController();
    }
    @Test
    @Tag("valid")
    public void validateNavigationToAddFlightPage() {
        String page = flightController.showAddFlightPage();
        Assertions.assertEquals("flights/addFlight", page);
    }
    @Test
    @Tag("invalid")
    public void validateErrorHandlingShowAddFlightPage() {
