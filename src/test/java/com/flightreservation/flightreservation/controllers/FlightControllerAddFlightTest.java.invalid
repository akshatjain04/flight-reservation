@ExtendWith(MockitoExtension.class)
public class FlightControllerAddFlightTest {
    @Mock
    FlightRepository flightRepository;
    @InjectMocks
    FlightController flightController;
    @Test
    @Tag("valid")
    public void successfulFlightAddition() {
        Flight flight = new Flight(); // TODO: add valid attributes
        ModelMap modelMap = new ModelMap();
        String view = flightController.addFlight(flight, modelMap);
        verify(flightRepository).save(flight);
        assertEquals("Flight Added Successfully", modelMap.get("msg"));
    }
    @Test
    @Tag("invalid")
    public void nullFlightAddition() {
        ModelMap modelMap = new ModelMap();
        doThrow(NullPointerException.class).when(flightRepository).save(null);
        assertThrows(NullPointerException.class, () -> flightController.addFlight(null, modelMap));
    }
    @Test
