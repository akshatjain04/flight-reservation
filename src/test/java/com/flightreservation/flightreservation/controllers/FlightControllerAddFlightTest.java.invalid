        assertThrows(RuntimeException.class, () -> flightController.addFlight(flight, modelMap));
    }
    @Test
    @Tag("valid")
    public void checkReturnViewAfterFlightAddition() {
        Flight flight = new Flight(); // TODO: add valid attributes
        ModelMap modelMap = new ModelMap();
        String view = flightController.addFlight(flight, modelMap);
        assertEquals("flights/addFlight", view);
