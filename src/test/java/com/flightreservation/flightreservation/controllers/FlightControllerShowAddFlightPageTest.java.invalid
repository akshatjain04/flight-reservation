package com.flightreservation.flightreservation.controllers;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.test.util.ReflectionTestUtils;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import com.flightreservation.flightreservation.domains.Flight;
import com.flightreservation.flightreservation.repositories.FlightRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.format.annotation.DateTimeFormat;
import org.springframework.stereotype.Controller;
import org.springframework.ui.ModelMap;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import java.util.Date;
import java.util.List;

public class FlightControllerShowAddFlightPageTest {
    
    @Test
    @Tag("valid")
    public void testShowAddFlightPage() {
        FlightController flightController = new FlightController();
        String result = flightController.showAddFlightPage();
        assertEquals("flights/addFlight", result);
    }
    @Test
    @Tag("integration")
    public void testShowAddFlightPageDifferentLogLevels() {
        FlightController flightController = new FlightController();
        
        Logger log = LoggerFactory.getLogger(FlightController.class);
        ReflectionTestUtils.setField(flightController, "LOGGER", log);
        log.info("Setting LOGGER level to INFO");
        String result = flightController.showAddFlightPage();
        assertEquals("flights/addFlight", result);
        log.debug("Setting LOGGER level to DEBUG");
        result = flightController.showAddFlightPage();
        assertEquals("flights/addFlight", result);
    }
}