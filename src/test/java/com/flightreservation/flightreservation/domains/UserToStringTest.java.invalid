package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertTrue;
import java.util.HashSet;
import java.util.Set;
import org.junit.jupiter.api.*;
import javax.persistence.*;

public class UserToStringTest {
    private User user;
    @BeforeEach
    public void setUp() {
        user = new User();
    }
    @Test
    @Tag("valid")
    public void toStringWithAllFieldsSet() {
        user.setFirstName("John");
        user.setLastName("Doe");
        user.setEmail("john.doe@example.com");
        user.setPassword("password123");
        String result = user.toString();
        assertEquals("User{firstName='John', lastName='Doe', email='john.doe@example.com', password='password123'}", result);
    }
    @Test
    @Tag("invalid")
    public void toStringWithNullFields() {
        user.setFirstName(null);
        user.setLastName("Doe");
        user.setEmail("john.doe@example.com");
        user.setPassword(null);
        String result = user.toString();
        assertEquals("User{firstName='null', lastName='Doe', email='john.doe@example.com', password='null'}", result);
    }
    @Test
    @Tag("boundary")
    public void toStringWithEmptyStringFields() {
        user.setFirstName("");
        user.setLastName("Doe");
        user.setEmail("john.doe@example.com");
        user.setPassword("");
        String result = user.toString();
        assertEquals("User{firstName='', lastName='Doe', email='john.doe@example.com', password=''}", result);
    }
    @Test
    @Tag("valid")
    public void toStringWithSpecialCharacters() {
        user.setFirstName("J@hn");
        user.setLastName("D#e");
        user.setEmail("john.doe@ex@mple.com");
        user.setPassword("p@ssw0rd");
        String result = user.toString();
        assertEquals("User{firstName='J@hn', lastName='D#e', email='john.doe@ex@mple.com', password='p@ssw0rd'}", result);
    }
    @Test
    @Tag("valid")
    public void toStringWithLongFieldValues() {
        String longString = "a".repeat(1000);
        user.setFirstName(longString);
        user.setLastName(longString);
        user.setEmail(longString + "@example.com");
        user.setPassword(longString);
        String result = user.toString();
        assertTrue(result.startsWith("User{firstName='" + longString));
        assertTrue(result.contains(", lastName='" + longString));
        assertTrue(result.contains(", email='" + longString + "@example.com"));
        assertTrue(result.contains(", password='" + longString + "'"));
    }
    @Test
    @Tag("valid")
    public void toStringWithRolesFieldSet() {
        Set<Role> roles = new HashSet<>();
        roles.add(new Role("USER"));
        user.setRoles(roles);
        user.setFirstName("John");
        user.setLastName("Doe");
        user.setEmail("john.doe@example.com");
        user.setPassword("password123");
        String result = user.toString();
        assertEquals("User{firstName='John', lastName='Doe', email='john.doe@example.com', password='password123'}", result);
    }
    @Test
    @Tag("boundary")
    public void toStringWithAllFieldsEmpty() {
        user.setFirstName("");
        user.setLastName("");
        user.setEmail("");
        user.setPassword("");
        String result = user.toString();
        assertEquals("User{firstName='', lastName='', email='', password=''}", result);
    }
    @Test
    @Tag("invalid")
    public void toStringWithAllFieldsNull() {
        user.setFirstName(null);
        user.setLastName(null);
        user.setEmail(null);
        user.setPassword(null);
        String result = user.toString();
        assertEquals("User{firstName='null', lastName='null', email='null', password='null'}", result);
    }
    @Test
    @Tag("valid")
    public void toStringWithMixedFieldValues() {
        user.setFirstName(null);
        user.setLastName("");
        user.setEmail("john.doe@example.com");
        user.setPassword("password123");
        String result = user.toString();
        assertEquals("User{firstName='null', lastName='', email='john.doe@example.com', password='password123'}", result);
    }
    @Test
    @Tag("valid")
    public void toStringWithUnicodeCharacters() {
        user.setFirstName("Jöhn");
        user.setLastName("Dœ");
        user.setEmail("john.doe@exämple.com");
        user.setPassword("p@ssw0rd");
        String result = user.toString();
        assertEquals("User{firstName='Jöhn', lastName='Dœ', email='john.doe@exämple.com', password='p@ssw0rd'}", result);
    }
}