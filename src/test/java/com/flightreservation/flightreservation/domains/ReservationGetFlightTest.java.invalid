package com.flightreservation.flightreservation.domains;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.springframework.boot.test.context.SpringBootTest;
import javax.persistence.Entity;
import javax.persistence.OneToOne;
import java.sql.Timestamp;
import java.util.Date;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;

@SpringBootTest
public class ReservationGetFlightTest extends AbstractEntity {
    private Reservation reservation;
    @BeforeEach
    public void setUp() {
        reservation = new Reservation();
    }
    @Test
    @Tag("valid")
    public void testGetFlightReturnsCorrectFlightObject() {
        Flight flight = new Flight();
        flight.setFlightNumber("123");
        reservation.setFlight(flight);
        assertEquals(flight, reservation.getFlight(), "The returned Flight object should be the same as the one set.");
    }
    @Test
    @Tag("valid")
    public void testGetFlightReturnsNullWhenNoFlightSet() {
        assertNull(reservation.getFlight(), "The returned value should be null when no Flight object is set.");
    }
    @Test
    @Tag("valid")
    public void testGetFlightReturnsCorrectFlightAfterMultipleSets() {
        Flight flight1 = new Flight();
        flight1.setFlightNumber("123");
        Flight flight2 = new Flight();
        flight2.setFlightNumber("456");
        reservation.setFlight(flight1);
        assertEquals(flight1, reservation.getFlight(), "The returned Flight object should be the first one set.");
        reservation.setFlight(flight2);
        assertEquals(flight2, reservation.getFlight(), "The returned Flight object should be the last one set.");
    }
    @Test
    @Tag("valid")
    public void testGetFlightReturnsCorrectFlightWithOtherFieldsSet() {
        Flight flight = new Flight();
        flight.setFlightNumber("123");
        Passenger passenger = new Passenger();
        passenger.setFirstName("John");
        passenger.setLastName("Doe");
        reservation.setFlight(flight);
        reservation.setCheckedin(true);
        reservation.setNumberOfBags(2);
        reservation.setPassenger(passenger);
        assertEquals(flight, reservation.getFlight(), "The returned Flight object should be the same as the one set even when other fields are set.");
    }
    @Test
    @Tag("integration")
    public void testGetFlightReturnsCorrectFlightAfterPersistence() {
        Flight flight = new Flight();
        flight.setFlightNumber("123");
        reservation.setFlight(flight);
        // Mock persistence behavior
        Reservation mockReservation = mock(Reservation.class);
        when(mockReservation.getFlight()).thenReturn(flight);
        assertEquals(flight, mockReservation.getFlight(), "The returned Flight object should be the same as the one set after persistence.");
    }
}
@Entity
class Reservation extends AbstractEntity {
    private boolean checkedIn;
    private int numberOfBags;
    private Passenger passenger;
    @OneToOne
    private Flight flight;
    public boolean isCheckedin() {
        return checkedIn;
    }
    public void setCheckedin(boolean checkedin) {
        this.checkedIn = checkedin;
    }
    public int getNumberOfBags() {
        return numberOfBags;
    }
    public void setNumberOfBags(int numberOfBags) {
        this.numberOfBags = numberOfBags;
    }
    public Passenger getPassenger() {
        return passenger;
    }
    public void setPassenger(Passenger passenger) {
        this.passenger = passenger;
    }
    public Flight getFlight() {
        return flight;
    }
    public void setFlight(Flight flight) {
        this.flight = flight;
    }
    @Override
    public String toString() {
        return "Reservation{" + "checkedin=" + checkedIn + ", numberOfBags=" + numberOfBags + ", passenger=" + passenger + ", flight=" + flight + '}';
    }
}
